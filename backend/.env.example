# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ── Database ─────────────────────────────────────────────────
DATABASE_URL="postgresql://theworkingapp:theworkingapp@localhost:5432/theworkingapp_dev"

# ── Redis ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# ── Blockchain ───────────────────────────────────────────────
# Primary chain (Phase 1)
PRIMARY_CHAIN_ID=8453
PRIMARY_RPC_URL=https://mainnet.base.org

# Testnet
TESTNET_CHAIN_ID=84532
TESTNET_RPC_URL=https://sepolia.base.org

# Platform deployer wallet (used for minting NFTs, deploying contracts)
PLATFORM_PRIVATE_KEY=0xYOUR_PLATFORM_WALLET_PRIVATE_KEY
PLATFORM_WALLET_ADDRESS=0xYOUR_PLATFORM_WALLET_ADDRESS

# Mediation key wallet (Gnosis Safe recommended in production)
MEDIATION_KEY_ADDRESS=0xYOUR_MEDIATION_KEY_ADDRESS

# Contract addresses (filled after deployment — see contracts/deployments/)
PLATFORM_FACTORY_ADDRESS=
PLATFORM_NFT_REGISTRY_ADDRESS=

# ── IPFS / Pinata ─────────────────────────────────────────────
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── On-Ramp ───────────────────────────────────────────────────
ONRAMPER_API_KEY=your_onramper_api_key
TRANSAK_API_KEY=your_transak_api_key
TRANSAK_ENV=STAGING  # STAGING | PRODUCTION

# ── Email ─────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@theworkingapp.io

# ── ZK-KYC ───────────────────────────────────────────────────
KYC_ORACLE_PRIVATE_KEY=0xYOUR_KYC_ORACLE_KEY
KYC_PROVIDER_URL=https://kyc-provider.example.com

# ── Platform ──────────────────────────────────────────────────
PLATFORM_FEE_BPS=150        # 1.5% in basis points
PORTION_GRANT_MAX_PCT=30
DEFAULT_MIN_MEMBERS=2
FRONTEND_URL=http://localhost:3000
